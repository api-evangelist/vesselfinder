          "name": "Track Container",
          "request": {
            "name": "Track Container",
            "description": {
              "content": "Look up the shipment for the specified container. Returns container origin,\ndestination, current vessel position, progress, and schedule events. May respond\nwith 202 Accepted while the request is processing — clients should poll the same\nURL no faster than every 60 seconds. Typical processing time is under one minute\nand may extend up to 15–20 minutes in worst case.\n",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "container",
                ":apiKey",
                ":containerNumber",
                ":sealine"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [],
              "variable": [
                {
                  "disabled": false,
                  "type": "any",
                  "value": "<string>",
                  "key": "apiKey",
                  "description": "(Required) Personal API key for the Container Tracking service."
                },
                {
                  "disabled": false,
                  "type": "any",
                  "value": "<string>",
                  "key": "containerNumber",
                  "description": "(Required) 11-character container number (four letters + seven digits)."
                },
                {
                  "disabled": false,
                  "type": "any",
                  "value": "AUTO",
                  "key": "sealine",
                  "description": "(Required) 4-character carrier SCAC code (e.g. `MSCU`). Use `AUTO` to let the service\nauto-detect the carrier.\n"
                }
              ]
            },
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "method": "GET",
            "auth": null
          },
